generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////
// ENUMS
//////////////////////////////////////

enum UserRole {
  ADMIN
  COMMERCIAL
}

enum PaymentMethod {
  CASH
  CHECK
  BANK_TRANSFER
  CREDIT_CARD
  MOBILE_PAYMENT
}

enum PurchaseInvoiceType {
  PURCHASE_ORDER
  PURCHASE_INVOICE
  PURCHASE_REFUND
}

enum SaleInvoiceType {
  QUOTATION
  DELIVERY_NOTE
  SALE_INVOICE
  SALE_REFUND
  SHIPPING_NOTE_INVOICE
}

enum InvoiceStatus {
  DRAFT
  VALIDATED
  PAID
  CANCELLED
  CLOSED
}

//////////////////////////////////////
// USER
//////////////////////////////////////

model User {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  password   String
  telephone  String?
  firstName  String?
  lastName   String?
  cin        String? 
  role       UserRole  @default(COMMERCIAL)
  createdAt  DateTime  @default(now())
}

//////////////////////////////////////
// CATEGORY
//////////////////////////////////////

model Category {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  products    Product[]
}

//////////////////////////////////////
// CLIENT
//////////////////////////////////////

model Client {
  id           Int             @id @default(autoincrement())
  name         String
  phone        String?
  address      String?
  taxNumber    String?
  email        String?
  cityId       Int?
  city         City?            @relation(fields: [cityId], references: [id])

  saleInvoices SaleInvoice[]
  payments     Payment[]
}

//////////////////////////////////////
// SUPPLIER
//////////////////////////////////////

model Supplier {
  id               Int                 @id @default(autoincrement())
  code             String
  name             String
  taxNumber        String?
  phone            String?
  address          String?
  bankRib          String?
  email            String?
  cityId           Int?
  city             City?                @relation(fields: [cityId], references: [id])

  purchaseInvoices PurchaseInvoice[]
  payments         Payment[]
}

//////////////////////////////////////
// PRODUCT
//////////////////////////////////////

model Product {
  id            Int       @id @default(autoincrement())
  reference     String?
  internalCode  String?
  name          String
  description   String?

  stock         Int       @default(0)
  minStock      Int       @default(0)
  purchasePrice Float @default(0)
  marginPercent Float @default(0)
  salePrice     Float @default(0)
  priceIncludingTax Float @default(0)
  discount      Float     @default(0)
  vat           Float     @default(19)
  img String?

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  brandId       Int?
  brand         Brand?    @relation(fields: [brandId], references: [id])

  purchaseInvoiceItems PurchaseInvoiceItem[]
  saleInvoiceItems     SaleInvoiceItem[]
}

//////////////////////////////////////
// PURCHASE INVOICE
//////////////////////////////////////

model PurchaseInvoice {
  id            Int                     @id @default(autoincrement())
  invoiceNumber String
  date          DateTime                @default(now())
  type          PurchaseInvoiceType
  status        InvoiceStatus           @default(DRAFT)
  
  originalInvoiceId Int?
  originalInvoice   PurchaseInvoice? @relation("PurchaseRefunds", fields: [originalInvoiceId], references: [id])
  refunds           PurchaseInvoice[] @relation("PurchaseRefunds")

  pdfUrl        String?

  supplierId    Int
  supplier      Supplier                @relation(fields: [supplierId], references: [id])

  items         PurchaseInvoiceItem[]

  payments      Payment[]               @relation("PurchaseInvoicePayments")

  totalHT       Float                   @default(0)
  totalTTC      Float                   @default(0)

  createdAt     DateTime                @default(now())
}

model PurchaseInvoiceItem {
  id        Int     @id @default(autoincrement())
  quantity  Int
  price     Float

  invoiceId Int
  productId Int

  invoice   PurchaseInvoice @relation(fields: [invoiceId], references: [id])
  product   Product         @relation(fields: [productId], references: [id])
}

//////////////////////////////////////
// SALE INVOICE
//////////////////////////////////////

model SaleInvoiceCity {
  id            Int         @id @default(autoincrement())
  saleInvoiceId Int
  cityId        Int
  createdAt     DateTime    @default(now())

  saleInvoice   SaleInvoice @relation(fields: [saleInvoiceId], references: [id], onDelete: Cascade)
  city          City        @relation(fields: [cityId], references: [id])

  @@unique([saleInvoiceId, cityId])
}

model DeliveryNoteConsolidation {
  id                        Int @id @default(autoincrement())
  consolidatedSaleInvoiceId Int
  consolidatedSaleInvoice   SaleInvoice @relation("ConsolidatedToSource", fields: [consolidatedSaleInvoiceId], references: [id], onDelete: Cascade)
  
  sourceDeliveryNoteId      Int
  sourceDeliveryNote        SaleInvoice @relation("SourceToConsolidated", fields: [sourceDeliveryNoteId], references: [id])
  
  createdAt                 DateTime @default(now())
  
  @@unique([consolidatedSaleInvoiceId, sourceDeliveryNoteId])
}

model SaleInvoice {
  id            Int                @id @default(autoincrement())
  invoiceNumber String
  date          DateTime           @default(now())
  startDate     DateTime?
  endDate       DateTime?
  type          SaleInvoiceType
  status        InvoiceStatus      @default(DRAFT)
  taxStamp      Float              @default(1)
  
  shippingNoteId Int?
  shippingNote   SaleInvoice?       @relation("ShippingNoteToDeliveryNotes", fields: [shippingNoteId], references: [id])
  deliveryNotes  SaleInvoice[]      @relation("ShippingNoteToDeliveryNotes")
  
  originalInvoiceId Int?
  originalInvoice   SaleInvoice? @relation("SaleRefunds", fields: [originalInvoiceId], references: [id])
  refunds           SaleInvoice[] @relation("SaleRefunds")
  consolidatedDeliveryNotes DeliveryNoteConsolidation[] @relation("ConsolidatedToSource")
  consolidatedInInvoice     DeliveryNoteConsolidation[] @relation("SourceToConsolidated")

  clientId      Int?
  client        Client?             @relation(fields: [clientId], references: [id])
  
  driverId      Int?
  driver        Driver?             @relation(fields: [driverId], references: [id])
  
  cities        SaleInvoiceCity[]

  items         SaleInvoiceItem[]
  payments      Payment[]          @relation("SaleInvoicePayments")

  totalHT       Float              @default(0)
  totalTTC      Float              @default(0)

  createdAt     DateTime           @default(now())
}

model SaleInvoiceItem {
  id        Int    @id @default(autoincrement())
  quantity  Int
  price     Float

  vatRate   Float   @default(0)
  vatAmount Float   @default(0)
  
  shippingNoteItemId Int?

  invoiceId Int
  productId Int

  invoice   SaleInvoice @relation(fields: [invoiceId], references: [id])
  product   Product     @relation(fields: [productId], references: [id])

  shippingNoteItem   SaleInvoiceItem? @relation("ItemToSource", fields: [shippingNoteItemId], references: [id])
  derivedItems       SaleInvoiceItem[] @relation("ItemToSource")
}

//////////////////////////////////////
// PAYMENTS
//////////////////////////////////////

model Payment {
  id       Int           @id @default(autoincrement())
  amount   Float
  method   PaymentMethod
  createdAt DateTime     @default(now())

  purchaseInvoiceId Int?
  purchaseInvoice   PurchaseInvoice? @relation("PurchaseInvoicePayments", fields: [purchaseInvoiceId], references: [id])

  supplierId        Int?
  supplier          Supplier?        @relation(fields: [supplierId], references: [id])

  saleInvoiceId     Int?
  saleInvoice       SaleInvoice?     @relation("SaleInvoicePayments", fields: [saleInvoiceId], references: [id])

  clientId          Int?
  client            Client?          @relation(fields: [clientId], references: [id])
}

//////////////////////////////////////
// COMPANY SETTINGS
//////////////////////////////////////

model CompanySettings {
  id          Int     @id @default(autoincrement())
  companyName String?
  address     String?
  phone       String?
  taxNumber   String?
  logo        String?
  rib         String?
  email       String?
}

model Driver {
  id            Int     @id @default(autoincrement())
  firstName     String
  lastName      String
  phone         String?
  email         String?
  cin           String?
  licenseNumber String?
  active        Boolean  @default(true)
  saleInvoices  SaleInvoice[]
  carId Int?
  car   Car? @relation(fields: [carId], references: [id])
}

model Car {
  id            Int      @id @default(autoincrement())
  registration  String   @unique
  brand         String?
  model         String?
  year          Int?
  driver   Driver[]

  createdAt DateTime @default(now())
}


model Brand {
  id        Int      @id @default(autoincrement())
  name      String    @unique
  description String?
  img String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model City {
  id        Int      @id @default(autoincrement())
  name      String
  state     String?
  country   String      @default("Tunisia")   
  clients   Client[]
  suppliers Supplier[]
  saleInvoices SaleInvoiceCity[]
  isActive  Boolean   @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt  
}

model HeroBanner {
  id        Int      @id @default(autoincrement())
  name        String?
  description String?
  img String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}